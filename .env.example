DATABASE_URL="postgresql://rezno:change_me_in_prod@localhost:5432/rezno?schema=public"
BETTER_AUTH_SECRET="replace-with-at-least-32-random-characters"
BETTER_AUTH_URL="http://localhost:3000"
REZNO_ADMIN_EMAILS="admin@example.com,owner@example.com"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Gate 4C outbound providers fail closed by default. The deterministic sink also
# requires an exact confirmation marker and a local/test or exact staging DB.
REZNO_ENV="local"
REZNO_OUTBOUND_SINK="disabled"
REZNO_OUTBOUND_SINK_CONFIRM=""

# Optional for Expo mobile app development and staging.
# localhost is for simulators or a local backend only. Physical devices must use
# an HTTPS staging origin or a LAN address reachable from the device.
EXPO_PUBLIC_REZNO_API_BASE_URL="http://localhost:3000"
