{
  "name": "rezno",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "npm run test:all",
    "test:unit": "tsx --test tests/commerce/unit/*.test.ts tests/identity/unit/*.test.ts tests/bookings/unit/*.test.ts tests/reviews/unit/*.test.ts tests/restaurants/unit/*.test.ts",
    "test:integration": "NODE_OPTIONS=--conditions=react-server tsx --test --test-concurrency=1 tests/commerce/integration/*.test.ts tests/identity/integration/*.test.ts tests/bookings/integration/*.test.ts tests/reviews/integration/*.test.ts tests/restaurants/integration/*.test.ts",
    "test:http": "tsx --test --test-concurrency=1 tests/commerce/http/*.test.ts tests/identity/http/*.test.ts tests/bookings/http/*.test.ts tests/reviews/http/*.test.ts tests/restaurants/http/*.test.ts",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:http",
    "test:commerce": "npm run test:all",
    "commerce:expire-pending-orders": "tsx scripts/commerce/expire-pending-orders.ts",
    "identity:backfill-owner-commerce": "tsx scripts/identity/backfill-owner-commerce-permissions.ts",
    "seed:staging:commerce-qa": "tsx scripts/staging/seed-commerce-qa.ts",
    "seed:staging:marketplace-demo": "tsx scripts/staging/seed-marketplace-demo.ts",
    "seed:staging:booking-qa": "tsx scripts/staging/seed-booking-qa.ts",
    "seed:staging:restaurant-qa": "tsx scripts/staging/seed-restaurant-qa.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@better-auth/expo": "^1.6.23",
    "@better-auth/prisma-adapter": "^1.6.23",
    "@date-fns/tz": "^1.5.0",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.42.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.22.0",
    "next": "16.2.9",
    "next-intl": "^4.13.1",
    "next-themes": "^0.4.6",
    "pg": "^8.22.0",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.6.1",
    "react": "19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.80.0",
    "shadcn": "^4.12.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^7.8.0",
    "server-only": "^0.0.1",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
