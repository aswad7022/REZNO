generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =====================================================
// IDENTITY
// =====================================================

enum AccountStatus {
  PENDING
  ACTIVE
  SUSPENDED
  BLOCKED
}

enum Gender {
  MALE
  FEMALE
  OTHER
  NOT_SPECIFIED
}

enum LanguageCode {
  AR
  EN
  TR
}

enum EntityStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum SystemRole {
  OWNER
  MANAGER
  RECEPTIONIST
  STAFF
}

enum StaffSelectionMode {
  NONE
  OPTIONAL
  REQUIRED
}

enum BusinessType {
  PHYSICAL
  ONLINE
  HYBRID
}

enum PricingType {
  FIXED
  STARTING_FROM
}

enum ServiceStatus {
  ACTIVE
  INACTIVE
}

// =====================================================
// IDENTITY
// =====================================================

model Person {
  id String @id @default(uuid()) @db.Uuid

  authUserId String @unique

  firstName String
  lastName  String?

  displayName String?

  phone String?

  avatarUrl String?

  gender Gender?

  preferredLanguage LanguageCode @default(AR)

  timezone String @default("Asia/Baghdad")

  status EntityStatus @default(ACTIVE)

  isOnboarded Boolean @default(false)

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  memberships OrganizationMember[]

  @@index([phone])
}

// =====================================================
// ORGANIZATION
// =====================================================

model Organization {
  id String @id @default(uuid()) @db.Uuid

  name String

  slug String @unique

  status EntityStatus @default(ACTIVE)

  businessType BusinessType @default(PHYSICAL)

  isVerified Boolean @default(false)

  isActive Boolean @default(true)

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  profile             BusinessProfile?
  settings            OrganizationSettings?
  organizationMembers OrganizationMember[]
  roles               Role[]
  branches            Branch[]
}

model BusinessProfile {
  id String @id @default(uuid()) @db.Uuid

  organizationId String @unique @db.Uuid

  legalName String?

  description String?

  website String?

  logoUrl String?

  coverImageUrl String?

  businessEmail String?

  businessPhone String?

  facebookUrl String?

  instagramUrl String?

  tiktokUrl String?

  youtubeUrl String?

  createdAt DateTime @default(now()) @db.Timestamptz(6)

  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id])
}

model OrganizationSettings {
  id String @id @default(uuid()) @db.Uuid

  organizationId String @unique @db.Uuid

  bookingEnabled Boolean @default(true)

  marketplaceVisible Boolean @default(true)

  staffSelectionMode StaffSelectionMode @default(OPTIONAL)

  allowOnlinePayments Boolean @default(false)

  cancellationWindowHours Int @default(24)

  createdAt DateTime @default(now()) @db.Timestamptz(6)

  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id])
}

model BusinessHour {
  id String @id @default(uuid()) @db.Uuid

  branchId String @db.Uuid

  dayOfWeek Int

  isOpen Boolean @default(true)

  openTime String

  closeTime String

  branch Branch @relation(fields: [branchId], references: [id])

  @@unique([branchId, dayOfWeek])
}

model Category {
  id String @id @default(uuid()) @db.Uuid

  name String

  slug String @unique

  icon String?

  createdAt DateTime @default(now()) @db.Timestamptz(6)

  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  services Service[]
}

model Service {
  id String @id @default(uuid()) @db.Uuid

  categoryId String @db.Uuid

  name String

  description String?

  imageUrl String?

  status ServiceStatus @default(ACTIVE)

  category Category @relation(fields: [categoryId], references: [id])

  branchServices BranchService[]

  createdAt DateTime @default(now()) @db.Timestamptz(6)

  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

model BranchService {
  id String @id @default(uuid()) @db.Uuid

  branchId String @db.Uuid

  serviceId String @db.Uuid

  price Decimal @db.Decimal(10, 2)

  pricingType PricingType @default(FIXED)

  durationMinutes Int

  isAvailable Boolean @default(true)

  branch Branch @relation(fields: [branchId], references: [id])

  service Service @relation(fields: [serviceId], references: [id])

  @@unique([branchId, serviceId])
}

model OrganizationMember {
  id String @id @default(uuid()) @db.Uuid

  personId String @db.Uuid

  organizationId String @db.Uuid

  roleId String @db.Uuid

  createdAt DateTime @default(now()) @db.Timestamptz(6)

  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  person Person @relation(fields: [personId], references: [id])

  organization Organization @relation(fields: [organizationId], references: [id])

  role Role @relation(fields: [roleId], references: [id])

  assignments BranchAssignment[]

  @@unique([personId, organizationId])
  @@index([organizationId])
  @@index([roleId])
}

model Role {
  id String @id @default(uuid()) @db.Uuid

  organizationId String @db.Uuid

  name String

  description String?

  systemRole SystemRole?

  isSystem Boolean @default(false)

  createdAt DateTime @default(now()) @db.Timestamptz(6)

  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id])

  organizationMembers OrganizationMember[]

  @@unique([organizationId, name])
}

model Branch {
  id String @id @default(uuid()) @db.Uuid

  organizationId String @db.Uuid

  name String

  slug String

  phone String?

  email String?

  timezone String @default("Asia/Baghdad")

  status EntityStatus @default(ACTIVE)

  addressLine1 String?

  addressLine2 String?

  city String?

  country String?

  latitude Decimal? @db.Decimal(9, 6)

  longitude Decimal? @db.Decimal(9, 6)

  createdAt DateTime @default(now()) @db.Timestamptz(6)

  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  deletedAt DateTime? @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id])

  assignments BranchAssignment[]

  businessHours BusinessHour[]

  branchServices BranchService[]

  @@unique([organizationId, slug])
}

model BranchAssignment {
  id String @id @default(uuid()) @db.Uuid

  memberId String @db.Uuid

  branchId String @db.Uuid

  createdAt DateTime @default(now()) @db.Timestamptz(6)

  member OrganizationMember @relation(fields: [memberId], references: [id])

  branch Branch @relation(fields: [branchId], references: [id])

  @@unique([memberId, branchId])
}
