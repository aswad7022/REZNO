generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Person {
  id                              String                          @id @default(uuid()) @db.Uuid
  authUserId                      String                          @unique
  firstName                       String
  lastName                        String?
  displayName                     String?
  phone                           String?
  avatarUrl                       String?
  gender                          Gender?
  preferredLanguage               LanguageCode                    @default(AR)
  timezone                        String                          @default("Asia/Baghdad")
  status                          EntityStatus                    @default(ACTIVE)
  isOnboarded                     Boolean                         @default(false)
  createdAt                       DateTime                        @default(now()) @db.Timestamptz(6)
  updatedAt                       DateTime                        @updatedAt @db.Timestamptz(6)
  deletedAt                       DateTime?                       @db.Timestamptz(6)
  memberships                     OrganizationMember[]
  customerBookings                Booking[]                       @relation("BookingCustomer")
  bookingChanges                  BookingStatusHistory[]
  requestedBookingChanges         BookingChangeRequest[]          @relation("BookingChangeRequester")
  restaurantReservationMutations  RestaurantReservationMutation[] @relation("RestaurantReservationMutationCustomer")
  businessAuditLogs               BusinessAuditLog[]              @relation("BusinessAuditLogActorPerson")
  reviews                         Review[]                        @relation("ReviewCustomer")
  notifications                   Notification[]
  customerConversations           Conversation[]                  @relation("ConversationCustomer")
  favoriteBusinesses              CustomerFavoriteBusiness[]
  favoriteServices                CustomerFavoriteService[]
  commerceAddresses               CustomerAddress[]
  commerceCarts                   Cart[]
  commerceCheckoutKeys            CheckoutIdempotency[]
  commerceOrders                  Order[]
  favoriteStores                  CustomerFavoriteStore[]
  favoriteProducts                CustomerFavoriteProduct[]
  sentOrganizationInvitations     OrganizationInvitation[]        @relation("OrganizationInvitationInvitedBy")
  receivedOrganizationInvitations OrganizationInvitation[]        @relation("OrganizationInvitationRecipient")

  @@index([phone])
}

model Organization {
  id                         String                         @id @default(uuid()) @db.Uuid
  name                       String
  slug                       String                         @unique
  status                     EntityStatus                   @default(ACTIVE)
  businessType               BusinessType                   @default(PHYSICAL)
  vertical                   BusinessVertical               @default(OTHER)
  isVerified                 Boolean                        @default(false)
  isActive                   Boolean                        @default(true)
  createdAt                  DateTime                       @default(now()) @db.Timestamptz(6)
  updatedAt                  DateTime                       @updatedAt @db.Timestamptz(6)
  deletedAt                  DateTime?                      @db.Timestamptz(6)
  branches                   Branch[]
  profile                    BusinessProfile?
  organizationMembers        OrganizationMember[]
  settings                   OrganizationSettings?
  roles                      Role[]
  services                   Service[]
  bookings                   Booking[]
  reviews                    Review[]
  restaurantTables           RestaurantTable[]
  menuCategories             MenuCategory[]
  menuItems                  MenuItem[]
  restaurantReservations     RestaurantReservationDetails[]
  businessOperationMutations BusinessOperationMutation[]
  businessAuditLogs          BusinessAuditLog[]
  notifications              Notification[]
  conversations              Conversation[]
  favoritedBy                CustomerFavoriteBusiness[]
  favoritedServices          CustomerFavoriteService[]
  invitations                OrganizationInvitation[]
  store                      Store?

  @@index([vertical])
  @@index([status, isActive, deletedAt])
}

model BusinessProfile {
  id               String       @id @default(uuid()) @db.Uuid
  organizationId   String       @unique @db.Uuid
  legalName        String?
  description      String?
  website          String?
  logoUrl          String?
  coverImageUrl    String?
  businessEmail    String?
  businessPhone    String?
  whatsappPhone    String?
  googleMapsUrl    String?
  bookingPolicy    String?
  faqItems         Json?
  galleryUrls      String[]     @default([])
  seoTitle         String?
  seoDescription   String?
  ogImageUrl       String?
  businessCategory String?
  facebookUrl      String?
  instagramUrl     String?
  tiktokUrl        String?
  youtubeUrl       String?
  createdAt        DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime     @updatedAt @db.Timestamptz(6)
  organization     Organization @relation(fields: [organizationId], references: [id])
}

model OrganizationSettings {
  id                      String             @id @default(uuid()) @db.Uuid
  organizationId          String             @unique @db.Uuid
  bookingEnabled          Boolean            @default(true)
  marketplaceVisible      Boolean            @default(true)
  staffSelectionMode      StaffSelectionMode @default(OPTIONAL)
  allowOnlinePayments     Boolean            @default(false)
  cancellationWindowHours Int                @default(24)
  createdAt               DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt               DateTime           @updatedAt @db.Timestamptz(6)
  organization            Organization       @relation(fields: [organizationId], references: [id])
}

model BusinessHour {
  id        String  @id @default(uuid()) @db.Uuid
  branchId  String  @db.Uuid
  dayOfWeek Int
  isOpen    Boolean @default(true)
  openTime  String
  closeTime String
  branch    Branch  @relation(fields: [branchId], references: [id])

  @@unique([branchId, dayOfWeek])
}

model Category {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  slug      String    @unique
  icon      String?
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  services  Service[]
}

model Service {
  id                 String                   @id @default(uuid()) @db.Uuid
  organizationId     String                   @db.Uuid
  categoryId         String                   @db.Uuid
  name               String
  description        String?
  imageUrl           String?
  status             ServiceStatus            @default(ACTIVE)
  staffSelectionMode StaffSelectionMode       @default(OPTIONAL)
  createdAt          DateTime                 @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime                 @updatedAt @db.Timestamptz(6)
  branchServices     BranchService[]
  staffAssignments   ServiceStaffAssignment[]
  reviews            Review[]
  category           Category                 @relation(fields: [categoryId], references: [id])
  organization       Organization             @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([categoryId])
  @@index([organizationId, status])
}

model BranchService {
  id              String                    @id @default(uuid()) @db.Uuid
  branchId        String                    @db.Uuid
  serviceId       String                    @db.Uuid
  price           Decimal                   @db.Decimal(10, 2)
  pricingType     PricingType               @default(FIXED)
  durationMinutes Int
  isAvailable     Boolean                   @default(true)
  branch          Branch                    @relation(fields: [branchId], references: [id])
  service         Service                   @relation(fields: [serviceId], references: [id])
  bookings        Booking[]
  favoritedBy     CustomerFavoriteService[]

  @@unique([branchId, serviceId])
  @@index([serviceId, isAvailable])
  @@index([isAvailable])
}

model OrganizationMember {
  id                         String                      @id @default(uuid()) @db.Uuid
  personId                   String                      @db.Uuid
  organizationId             String                      @db.Uuid
  roleId                     String                      @db.Uuid
  createdAt                  DateTime                    @default(now()) @db.Timestamptz(6)
  updatedAt                  DateTime                    @updatedAt @db.Timestamptz(6)
  status                     EntityStatus                @default(ACTIVE)
  deletedAt                  DateTime?                   @db.Timestamptz(6)
  photoUrl                   String?
  bio                        String?
  specialties                String[]                    @default([])
  publicSlug                 String?
  isPublicProfessional       Boolean                     @default(false)
  assignments                BranchAssignment[]
  availabilities             Availability[]
  blockedTimes               BlockedTime[]
  bookings                   Booking[]
  serviceAssignments         ServiceStaffAssignment[]
  reviews                    Review[]
  reviewReplies              Review[]                    @relation("ReviewBusinessReplyAuthor")
  proposedBookingChanges     BookingChangeRequest[]
  businessOperationMutations BusinessOperationMutation[]
  businessAuditLogs          BusinessAuditLog[]
  organization               Organization                @relation(fields: [organizationId], references: [id])
  person                     Person                      @relation(fields: [personId], references: [id])
  role                       Role                        @relation(fields: [roleId], references: [id])

  @@unique([personId, organizationId])
  @@unique([organizationId, publicSlug])
  @@index([organizationId])
  @@index([organizationId, status, deletedAt])
  @@index([organizationId, isPublicProfessional])
  @@index([roleId])
}

model Role {
  id                  String                   @id @default(uuid()) @db.Uuid
  organizationId      String                   @db.Uuid
  name                String
  description         String?
  systemRole          SystemRole?
  commercePermissions CommercePermission[]     @default([])
  isSystem            Boolean                  @default(false)
  createdAt           DateTime                 @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime                 @updatedAt @db.Timestamptz(6)
  organizationMembers OrganizationMember[]
  invitations         OrganizationInvitation[]
  organization        Organization             @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, name])
}

model Branch {
  id                     String                         @id @default(uuid()) @db.Uuid
  organizationId         String                         @db.Uuid
  name                   String
  slug                   String
  phone                  String?
  email                  String?
  timezone               String                         @default("Asia/Baghdad")
  status                 EntityStatus                   @default(ACTIVE)
  addressLine1           String?
  addressLine2           String?
  city                   String?
  country                String?
  latitude               Decimal?                       @db.Decimal(9, 6)
  longitude              Decimal?                       @db.Decimal(9, 6)
  locationLabel          String?
  nearbyLandmark         String?
  locationInstructions   String?
  createdAt              DateTime                       @default(now()) @db.Timestamptz(6)
  updatedAt              DateTime                       @updatedAt @db.Timestamptz(6)
  deletedAt              DateTime?                      @db.Timestamptz(6)
  organization           Organization                   @relation(fields: [organizationId], references: [id])
  assignments            BranchAssignment[]
  branchServices         BranchService[]
  businessHours          BusinessHour[]
  availabilities         Availability[]
  blockedTimes           BlockedTime[]
  bookings               Booking[]
  restaurantTables       RestaurantTable[]
  restaurantReservations RestaurantReservationDetails[]

  @@unique([organizationId, slug])
  @@index([organizationId, status, deletedAt])
  @@index([city])
  @@index([latitude, longitude])
}

model OrganizationInvitation {
  id                String                       @id @default(uuid()) @db.Uuid
  organizationId    String                       @db.Uuid
  email             String
  normalizedEmail   String
  roleId            String?                      @db.Uuid
  invitedByPersonId String                       @db.Uuid
  recipientPersonId String?                      @db.Uuid
  status            OrganizationInvitationStatus @default(PENDING)
  acceptedAt        DateTime?                    @db.Timestamptz(6)
  declinedAt        DateTime?                    @db.Timestamptz(6)
  cancelledAt       DateTime?                    @db.Timestamptz(6)
  expiresAt         DateTime?                    @db.Timestamptz(6)
  createdAt         DateTime                     @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime                     @updatedAt @db.Timestamptz(6)
  organization      Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role              Role?                        @relation(fields: [roleId], references: [id], onDelete: SetNull)
  invitedByPerson   Person                       @relation("OrganizationInvitationInvitedBy", fields: [invitedByPersonId], references: [id], onDelete: Cascade)
  recipientPerson   Person?                      @relation("OrganizationInvitationRecipient", fields: [recipientPersonId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([normalizedEmail])
  @@index([recipientPersonId])
  @@index([status])
  @@index([organizationId, normalizedEmail, status])
}

model RestaurantTable {
  id            String                         @id @default(uuid()) @db.Uuid
  businessId    String                         @db.Uuid
  branchId      String?                        @db.Uuid
  name          String
  code          String?
  capacity      Int
  area          String?
  floor         String?
  positionLabel String?
  isActive      Boolean                        @default(true)
  createdAt     DateTime                       @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime                       @updatedAt @db.Timestamptz(6)
  business      Organization                   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branch        Branch?                        @relation(fields: [branchId], references: [id], onDelete: SetNull)
  reservations  RestaurantReservationDetails[]

  @@index([businessId])
  @@index([branchId])
  @@index([isActive])
  @@index([capacity])
}

model MenuCategory {
  id          String       @id @default(uuid()) @db.Uuid
  businessId  String       @db.Uuid
  name        String
  description String?
  sortOrder   Int          @default(0)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @db.Timestamptz(6)
  business    Organization @relation(fields: [businessId], references: [id], onDelete: Cascade)
  items       MenuItem[]

  @@index([businessId])
  @@index([isActive])
  @@index([sortOrder])
}

model MenuItem {
  id                 String                      @id @default(uuid()) @db.Uuid
  businessId         String                      @db.Uuid
  menuCategoryId     String                      @db.Uuid
  name               String
  description        String?
  price              Decimal                     @db.Decimal(10, 2)
  currency           String                      @default("IQD")
  imageUrl           String?
  isAvailable        Boolean                     @default(true)
  sortOrder          Int                         @default(0)
  preparationMinutes Int?
  createdAt          DateTime                    @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime                    @updatedAt @db.Timestamptz(6)
  business           Organization                @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category           MenuCategory                @relation(fields: [menuCategoryId], references: [id], onDelete: Cascade)
  reservationItems   RestaurantReservationItem[]

  @@index([businessId])
  @@index([menuCategoryId])
  @@index([isAvailable])
}

model BranchAssignment {
  id        String             @id @default(uuid()) @db.Uuid
  memberId  String             @db.Uuid
  branchId  String             @db.Uuid
  createdAt DateTime           @default(now()) @db.Timestamptz(6)
  branch    Branch             @relation(fields: [branchId], references: [id])
  member    OrganizationMember @relation(fields: [memberId], references: [id])

  @@unique([memberId, branchId])
}

model Availability {
  id        String             @id @default(uuid()) @db.Uuid
  memberId  String             @db.Uuid
  branchId  String             @db.Uuid
  dayOfWeek Int
  startTime String
  endTime   String
  isActive  Boolean            @default(true)
  createdAt DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt DateTime           @updatedAt @db.Timestamptz(6)
  member    OrganizationMember @relation(fields: [memberId], references: [id])
  branch    Branch             @relation(fields: [branchId], references: [id])

  @@unique([memberId, branchId, dayOfWeek, startTime, endTime])
  @@index([branchId, dayOfWeek, isActive])
}

model BlockedTime {
  id        String              @id @default(uuid()) @db.Uuid
  branchId  String              @db.Uuid
  memberId  String?             @db.Uuid
  startsAt  DateTime            @db.Timestamptz(6)
  endsAt    DateTime            @db.Timestamptz(6)
  reason    String?
  createdAt DateTime            @default(now()) @db.Timestamptz(6)
  updatedAt DateTime            @updatedAt @db.Timestamptz(6)
  branch    Branch              @relation(fields: [branchId], references: [id])
  member    OrganizationMember? @relation(fields: [memberId], references: [id])

  @@index([branchId, startsAt, endsAt])
  @@index([memberId, startsAt, endsAt])
}

model Booking {
  id                                 String                          @id @default(uuid()) @db.Uuid
  organizationId                     String                          @db.Uuid
  branchId                           String                          @db.Uuid
  customerId                         String                          @db.Uuid
  branchServiceId                    String?                         @db.Uuid
  memberId                           String?                         @db.Uuid
  status                             BookingStatus                   @default(CONFIRMED)
  startsAt                           DateTime                        @db.Timestamptz(6)
  endsAt                             DateTime                        @db.Timestamptz(6)
  serviceNameSnapshot                String
  customerNameSnapshot               String
  priceSnapshot                      Decimal                         @db.Decimal(10, 2)
  notes                              String?
  cancellationReason                 String?
  cancelledAt                        DateTime?                       @db.Timestamptz(6)
  creationIdempotencyKey             String?                         @db.Uuid
  creationRequestHash                String?                         @db.VarChar(64)
  customerCancellationIdempotencyKey String?                         @db.Uuid
  customerCancellationRequestHash    String?                         @db.VarChar(64)
  createdAt                          DateTime                        @default(now()) @db.Timestamptz(6)
  updatedAt                          DateTime                        @updatedAt @db.Timestamptz(6)
  organization                       Organization                    @relation(fields: [organizationId], references: [id])
  branch                             Branch                          @relation(fields: [branchId], references: [id])
  customer                           Person                          @relation("BookingCustomer", fields: [customerId], references: [id])
  branchService                      BranchService?                  @relation(fields: [branchServiceId], references: [id])
  member                             OrganizationMember?             @relation(fields: [memberId], references: [id])
  statusHistory                      BookingStatusHistory[]
  changeRequests                     BookingChangeRequest[]
  review                             Review?
  restaurantReservation              RestaurantReservationDetails?
  restaurantReservationMutations     RestaurantReservationMutation[]
  conversations                      Conversation[]

  @@unique([customerId, creationIdempotencyKey])
  @@unique([customerId, customerCancellationIdempotencyKey])
  @@index([organizationId, startsAt])
  @@index([branchId, startsAt, endsAt])
  @@index([customerId, startsAt])
  @@index([memberId, startsAt, endsAt])
  @@index([status, startsAt])
}

model BookingStatusHistory {
  id                String         @id @default(uuid()) @db.Uuid
  bookingId         String         @db.Uuid
  fromStatus        BookingStatus?
  toStatus          BookingStatus
  changedByPersonId String?        @db.Uuid
  note              String?
  createdAt         DateTime       @default(now()) @db.Timestamptz(6)
  booking           Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  changedBy         Person?        @relation(fields: [changedByPersonId], references: [id])

  @@index([bookingId, createdAt])
}

model ServiceStaffAssignment {
  id        String             @id @default(uuid()) @db.Uuid
  serviceId String             @db.Uuid
  memberId  String             @db.Uuid
  createdAt DateTime           @default(now()) @db.Timestamptz(6)
  service   Service            @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  member    OrganizationMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([serviceId, memberId])
  @@index([memberId])
}

model BookingChangeRequest {
  id                       String                     @id @default(uuid()) @db.Uuid
  bookingId                String                     @db.Uuid
  requestedByPersonId      String                     @db.Uuid
  proposedMemberId         String?                    @db.Uuid
  proposedStartsAt         DateTime                   @db.Timestamptz(6)
  proposedEndsAt           DateTime                   @db.Timestamptz(6)
  status                   BookingChangeRequestStatus @default(PENDING)
  createdAt                DateTime                   @default(now()) @db.Timestamptz(6)
  respondedAt              DateTime?                  @db.Timestamptz(6)
  creationIdempotencyKey   String?                    @db.Uuid
  creationRequestHash      String?                    @db.VarChar(64)
  bookingUpdatedAtSnapshot DateTime?                  @db.Timestamptz(6)
  booking                  Booking                    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  requestedBy              Person                     @relation("BookingChangeRequester", fields: [requestedByPersonId], references: [id])
  proposedMember           OrganizationMember?        @relation(fields: [proposedMemberId], references: [id])

  @@unique([requestedByPersonId, creationIdempotencyKey], map: "BookingChangeRequest_requester_creationKey_key")
  @@index([bookingId, status])
  @@index([requestedByPersonId])
}

model Review {
  id                    String              @id @default(uuid()) @db.Uuid
  bookingId             String              @unique @db.Uuid
  customerId            String              @db.Uuid
  organizationId        String              @db.Uuid
  serviceId             String              @db.Uuid
  memberId              String?             @db.Uuid
  rating                Int
  comment               String?
  status                ReviewStatus        @default(VISIBLE)
  businessReply         String?
  businessReplyAuthorId String?             @db.Uuid
  businessRepliedAt     DateTime?           @db.Timestamptz(6)
  createdAt             DateTime            @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime            @updatedAt @db.Timestamptz(6)
  booking               Booking             @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  customer              Person              @relation("ReviewCustomer", fields: [customerId], references: [id])
  organization          Organization        @relation(fields: [organizationId], references: [id])
  service               Service             @relation(fields: [serviceId], references: [id])
  member                OrganizationMember? @relation(fields: [memberId], references: [id])
  businessReplyAuthor   OrganizationMember? @relation("ReviewBusinessReplyAuthor", fields: [businessReplyAuthorId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([serviceId])
  @@index([memberId])
  @@index([customerId])
  @@index([status, createdAt])
  @@index([organizationId, businessRepliedAt])
  @@index([businessReplyAuthorId])
}

model CustomerFavoriteBusiness {
  id             String       @id @default(uuid()) @db.Uuid
  customerId     String       @db.Uuid
  organizationId String       @db.Uuid
  createdAt      DateTime     @default(now()) @db.Timestamptz(6)
  customer       Person       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([customerId, organizationId])
  @@index([customerId, createdAt])
  @@index([organizationId])
}

model CustomerFavoriteService {
  id              String        @id @default(uuid()) @db.Uuid
  customerId      String        @db.Uuid
  organizationId  String        @db.Uuid
  branchServiceId String        @db.Uuid
  createdAt       DateTime      @default(now()) @db.Timestamptz(6)
  customer        Person        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branchService   BranchService @relation(fields: [branchServiceId], references: [id], onDelete: Cascade)

  @@unique([customerId, branchServiceId])
  @@index([customerId, createdAt])
  @@index([branchServiceId])
  @@index([organizationId])
}

model RestaurantReservationDetails {
  id                  String                      @id @default(uuid()) @db.Uuid
  bookingId           String                      @unique @db.Uuid
  businessId          String                      @db.Uuid
  branchId            String?                     @db.Uuid
  tableId             String                      @db.Uuid
  guestCount          Int
  reservationDateTime DateTime                    @db.Timestamptz(6)
  durationMinutes     Int                         @default(90)
  seatingArea         String?
  customerNote        String?
  createdAt           DateTime                    @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime                    @updatedAt @db.Timestamptz(6)
  booking             Booking                     @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  business            Organization                @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branch              Branch?                     @relation(fields: [branchId], references: [id], onDelete: SetNull)
  table               RestaurantTable             @relation(fields: [tableId], references: [id])
  items               RestaurantReservationItem[]

  @@index([businessId])
  @@index([branchId])
  @@index([tableId])
  @@index([tableId, reservationDateTime])
  @@index([reservationDateTime])
}

model RestaurantReservationItem {
  id                             String                       @id @default(uuid()) @db.Uuid
  restaurantReservationDetailsId String                       @db.Uuid
  menuItemId                     String                       @db.Uuid
  quantity                       Int                          @default(1)
  unitPrice                      Decimal                      @db.Decimal(10, 2)
  itemNameSnapshot               String?
  currencySnapshot               String?                      @db.VarChar(3)
  note                           String?
  createdAt                      DateTime                     @default(now()) @db.Timestamptz(6)
  updatedAt                      DateTime                     @updatedAt @db.Timestamptz(6)
  reservation                    RestaurantReservationDetails @relation(fields: [restaurantReservationDetailsId], references: [id], onDelete: Cascade)
  menuItem                       MenuItem                     @relation(fields: [menuItemId], references: [id])

  @@unique([restaurantReservationDetailsId, menuItemId])
  @@index([restaurantReservationDetailsId])
  @@index([menuItemId])
}

model RestaurantReservationMutation {
  id                       String                            @id @default(uuid()) @db.Uuid
  bookingId                String                            @db.Uuid
  customerId               String                            @db.Uuid
  type                     RestaurantReservationMutationType
  idempotencyKey           String                            @db.Uuid
  requestHash              String                            @db.VarChar(64)
  bookingUpdatedAtSnapshot DateTime                          @db.Timestamptz(6)
  resultBookingUpdatedAt   DateTime                          @db.Timestamptz(6)
  createdAt                DateTime                          @default(now()) @db.Timestamptz(6)
  booking                  Booking                           @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  customer                 Person                            @relation("RestaurantReservationMutationCustomer", fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, idempotencyKey])
  @@index([bookingId, type, createdAt])
}

model BusinessOperationMutation {
  id                String             @id @default(uuid()) @db.Uuid
  organizationId    String             @db.Uuid
  actorMembershipId String             @db.Uuid
  idempotencyKey    String             @db.Uuid
  action            String             @db.VarChar(80)
  requestHash       String             @db.VarChar(64)
  targetType        String             @db.VarChar(60)
  targetId          String?            @db.Uuid
  resultVersion     DateTime           @db.Timestamptz(6)
  result            Json?
  createdAt         DateTime           @default(now()) @db.Timestamptz(6)
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  actorMembership   OrganizationMember @relation(fields: [actorMembershipId], references: [id], onDelete: Restrict)

  @@unique([organizationId, idempotencyKey])
  @@index([organizationId, action, createdAt])
  @@index([targetType, targetId])
  @@index([actorMembershipId, createdAt])
}

model BusinessAuditLog {
  id                String             @id @default(uuid()) @db.Uuid
  organizationId    String             @db.Uuid
  actorMembershipId String             @db.Uuid
  actorPersonId     String             @db.Uuid
  action            String             @db.VarChar(80)
  targetType        String             @db.VarChar(60)
  targetId          String             @db.Uuid
  before            Json?
  after             Json?
  createdAt         DateTime           @default(now()) @db.Timestamptz(6)
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  actorMembership   OrganizationMember @relation(fields: [actorMembershipId], references: [id], onDelete: Restrict)
  actorPerson       Person             @relation("BusinessAuditLogActorPerson", fields: [actorPersonId], references: [id], onDelete: Restrict)

  @@index([organizationId, createdAt])
  @@index([organizationId, action, createdAt])
  @@index([targetType, targetId])
  @@index([actorMembershipId, createdAt])
}

model User {
  id                   String          @id
  name                 String
  email                String          @unique
  emailVerified        Boolean         @default(false)
  image                String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  accounts             Account[]
  sessions             Session[]
  sentMessages         Message[]
  adminConversations   Conversation[]  @relation("ConversationAdminUser")
  createdNotifications Notification[]  @relation("NotificationCreator")
  adminAuditLogs       AdminAuditLog[] @relation("AdminAuditLogUser")
  adminAccess          AdminAccess?
  grantedAdminAccesses AdminAccess[]   @relation("AdminAccessGrantedBy")

  @@map("user")
}

model AdminAccess {
  id          String            @id @default(uuid()) @db.Uuid
  userId      String            @unique
  role        AdminAccessRole   @default(ADMIN)
  status      AdminAccessStatus @default(ACTIVE)
  permissions String[]          @default([])
  expiresAt   DateTime?         @db.Timestamptz(6)
  grantedById String?
  createdAt   DateTime          @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime          @updatedAt @db.Timestamptz(6)
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  grantedBy   User?             @relation("AdminAccessGrantedBy", fields: [grantedById], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([status, expiresAt])
  @@index([role])
}

model AdminAuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  adminUserId String
  action      String
  targetType  String?
  targetId    String?
  metadata    Json?
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  adminUser   User     @relation("AdminAuditLogUser", fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
}

model Notification {
  id                String               @id @default(uuid()) @db.Uuid
  title             String
  body              String
  audience          NotificationAudience
  priority          NotificationPriority @default(NORMAL)
  eventKey          String?              @unique
  metadata          Json?
  recipientPersonId String?              @db.Uuid
  businessId        String?              @db.Uuid
  createdByUserId   String?
  createdAt         DateTime             @default(now()) @db.Timestamptz(6)
  recipientPerson   Person?              @relation(fields: [recipientPersonId], references: [id], onDelete: Cascade)
  business          Organization?        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdBy         User?                @relation("NotificationCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([audience, createdAt])
  @@index([recipientPersonId, createdAt])
  @@index([businessId, createdAt])
}

model Conversation {
  id          String           @id @default(uuid()) @db.Uuid
  type        ConversationType
  businessId  String?          @db.Uuid
  customerId  String?          @db.Uuid
  bookingId   String?          @db.Uuid
  adminUserId String?
  subject     String?
  createdAt   DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime         @updatedAt @db.Timestamptz(6)
  business    Organization?    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer    Person?          @relation("ConversationCustomer", fields: [customerId], references: [id], onDelete: Cascade)
  booking     Booking?         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  adminUser   User?            @relation("ConversationAdminUser", fields: [adminUserId], references: [id], onDelete: SetNull)
  messages    Message[]

  @@unique([businessId, customerId, bookingId])
  @@index([type, updatedAt])
  @@index([businessId, updatedAt])
  @@index([customerId, updatedAt])
  @@index([bookingId, updatedAt])
  @@index([adminUserId, updatedAt])
}

model Message {
  id             String       @id @default(uuid()) @db.Uuid
  conversationId String       @db.Uuid
  senderUserId   String
  body           String
  createdAt      DateTime     @default(now()) @db.Timestamptz(6)
  readAt         DateTime?    @db.Timestamptz(6)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderUserId, createdAt])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Store {
  id                         String                  @id @default(uuid()) @db.Uuid
  organizationId             String                  @unique @db.Uuid
  slug                       String                  @unique
  name                       String
  description                String?
  supportPhone               String?
  logoUrl                    String?
  coverImageUrl              String?
  status                     StoreStatus             @default(DRAFT)
  currency                   String                  @default("IQD") @db.VarChar(3)
  deliveryEnabled            Boolean                 @default(false)
  pickupEnabled              Boolean                 @default(false)
  deliveryFee                Decimal                 @default(0) @db.Decimal(18, 3)
  minimumOrderValue          Decimal                 @default(0) @db.Decimal(18, 3)
  preparationEstimateMinutes Int?
  deliveryEstimateMinutes    Int?
  deliveryCity               String?
  deliveryArea               String?
  pickupCity                 String?
  pickupArea                 String?
  pickupStreet               String?
  pickupAdditionalDetails    String?
  pickupInstructions         String?
  reviewReason               String?
  suspensionReason           String?
  archiveReason              String?
  submittedAt                DateTime?               @db.Timestamptz(6)
  reviewedAt                 DateTime?               @db.Timestamptz(6)
  reviewedByUserId           String?
  publishedAt                DateTime?               @db.Timestamptz(6)
  suspendedAt                DateTime?               @db.Timestamptz(6)
  archivedAt                 DateTime?               @db.Timestamptz(6)
  createdAt                  DateTime                @default(now()) @db.Timestamptz(6)
  updatedAt                  DateTime                @updatedAt @db.Timestamptz(6)
  organization               Organization            @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  products                   Product[]
  variants                   ProductVariant[]
  carts                      Cart[]
  orders                     Order[]
  favoritedBy                CustomerFavoriteStore[]

  @@index([organizationId, status])
  @@index([status, publishedAt])
}

model MarketplaceCategory {
  id             String                    @id @default(uuid()) @db.Uuid
  slug           String                    @unique
  name           String
  normalizedName String
  status         MarketplaceCategoryStatus @default(ACTIVE)
  displayOrder   Int                       @default(0)
  createdAt      DateTime                  @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime                  @updatedAt @db.Timestamptz(6)
  products       Product[]

  @@index([status, displayOrder])
  @@index([normalizedName])
}

model Product {
  id                   String                    @id @default(uuid()) @db.Uuid
  storeId              String                    @db.Uuid
  categoryId           String                    @db.Uuid
  slug                 String
  name                 String
  normalizedSearchText String
  description          String?
  status               ProductStatus             @default(DRAFT)
  publishedAt          DateTime?                 @db.Timestamptz(6)
  suspensionReason     String?
  suspendedAt          DateTime?                 @db.Timestamptz(6)
  archivedAt           DateTime?                 @db.Timestamptz(6)
  createdAt            DateTime                  @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime                  @updatedAt @db.Timestamptz(6)
  store                Store                     @relation(fields: [storeId], references: [id], onDelete: Restrict)
  category             MarketplaceCategory       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  variants             ProductVariant[]
  media                ProductMedia[]
  orderItems           OrderItem[]
  favoritedBy          CustomerFavoriteProduct[]

  @@unique([storeId, slug])
  @@unique([id, storeId])
  @@index([storeId, status, publishedAt])
  @@index([categoryId, status, publishedAt])
  @@index([normalizedSearchText])
  @@index([createdAt, id])
}

model ProductVariant {
  id             String                 @id @default(uuid()) @db.Uuid
  productId      String                 @db.Uuid
  storeId        String                 @db.Uuid
  sku            String
  title          String
  isDefault      Boolean                @default(false)
  optionValues   Json                   @default("{}")
  optionKey      String
  price          Decimal                @db.Decimal(18, 3)
  compareAtPrice Decimal?               @db.Decimal(18, 3)
  currency       String                 @default("IQD") @db.VarChar(3)
  status         ProductVariantStatus   @default(ACTIVE)
  archivedAt     DateTime?              @db.Timestamptz(6)
  createdAt      DateTime               @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime               @updatedAt @db.Timestamptz(6)
  product        Product                @relation(fields: [productId, storeId], references: [id, storeId], onDelete: Restrict)
  store          Store                  @relation(fields: [storeId], references: [id], onDelete: Restrict)
  media          ProductMedia[]
  inventory      InventoryItem?
  cartItems      CartItem[]
  reservations   InventoryReservation[]
  orderItems     OrderItem[]

  @@unique([storeId, sku])
  @@unique([productId, optionKey])
  @@index([productId, status])
  @@index([storeId, status])
}

model ProductMedia {
  id        String           @id @default(uuid()) @db.Uuid
  productId String           @db.Uuid
  variantId String?          @db.Uuid
  url       String
  mediaType ProductMediaType @default(IMAGE)
  sortOrder Int              @default(0)
  altText   String?
  createdAt DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt DateTime         @updatedAt @db.Timestamptz(6)
  product   Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   ProductVariant?  @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([productId, sortOrder])
  @@index([variantId])
}

model InventoryItem {
  id                String                 @id @default(uuid()) @db.Uuid
  variantId         String                 @unique @db.Uuid
  onHand            Int                    @default(0)
  reserved          Int                    @default(0)
  version           Int                    @default(0)
  lowStockThreshold Int?
  createdAt         DateTime               @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime               @updatedAt @db.Timestamptz(6)
  variant           ProductVariant         @relation(fields: [variantId], references: [id], onDelete: Restrict)
  movements         StockMovement[]
  reservations      InventoryReservation[]
}

model InventoryReservation {
  id               String                     @id @default(uuid()) @db.Uuid
  orderId          String                     @db.Uuid
  orderItemId      String                     @unique @db.Uuid
  productVariantId String                     @db.Uuid
  inventoryItemId  String                     @db.Uuid
  quantity         Int
  status           InventoryReservationStatus @default(ACTIVE)
  deterministicKey String                     @unique
  expiresAt        DateTime                   @db.Timestamptz(6)
  releasedAt       DateTime?                  @db.Timestamptz(6)
  consumedAt       DateTime?                  @db.Timestamptz(6)
  createdAt        DateTime                   @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime                   @updatedAt @db.Timestamptz(6)
  order            Order                      @relation(fields: [orderId], references: [id], onDelete: Restrict)
  orderItem        OrderItem                  @relation(fields: [orderItemId], references: [id], onDelete: Restrict)
  productVariant   ProductVariant             @relation(fields: [productVariantId], references: [id], onDelete: Restrict)
  inventoryItem    InventoryItem              @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  movements        StockMovement[]

  @@index([orderId, status])
  @@index([status, expiresAt])
  @@index([inventoryItemId])
}

model StockMovement {
  id                String                @id @default(uuid()) @db.Uuid
  inventoryItemId   String                @db.Uuid
  orderId           String?               @db.Uuid
  reservationId     String?               @db.Uuid
  type              StockMovementType
  quantity          Int
  onHandDelta       Int
  reservedDelta     Int
  resultingOnHand   Int
  resultingReserved Int
  idempotencyKey    String                @unique
  actorType         OrderActorType
  actorId           String?
  reason            String?
  metadata          Json?
  createdAt         DateTime              @default(now()) @db.Timestamptz(6)
  inventoryItem     InventoryItem         @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  order             Order?                @relation(fields: [orderId], references: [id], onDelete: Restrict)
  reservation       InventoryReservation? @relation(fields: [reservationId], references: [id], onDelete: Restrict)

  @@index([inventoryItemId, createdAt])
  @@index([orderId, createdAt])
  @@index([reservationId])
}

model CustomerAddress {
  id                String    @id @default(uuid()) @db.Uuid
  customerId        String    @db.Uuid
  label             String?
  recipientName     String
  phone             String
  city              String
  area              String
  street            String
  additionalDetails String
  landmark          String?
  latitude          Decimal?  @db.Decimal(9, 6)
  longitude         Decimal?  @db.Decimal(9, 6)
  isDefault         Boolean   @default(false)
  archivedAt        DateTime? @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)
  customer          Person    @relation(fields: [customerId], references: [id], onDelete: Restrict)

  @@index([customerId, archivedAt, updatedAt])
}

model Cart {
  id         String     @id @default(uuid()) @db.Uuid
  customerId String     @db.Uuid
  storeId    String     @db.Uuid
  status     CartStatus @default(ACTIVE)
  currency   String     @default("IQD") @db.VarChar(3)
  version    Int        @default(1)
  expiresAt  DateTime?  @db.Timestamptz(6)
  createdAt  DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime   @updatedAt @db.Timestamptz(6)
  customer   Person     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  store      Store      @relation(fields: [storeId], references: [id], onDelete: Restrict)
  items      CartItem[]

  @@index([customerId, status])
  @@index([status, expiresAt])
  @@index([storeId])
}

model CartItem {
  id                String         @id @default(uuid()) @db.Uuid
  cartId            String         @db.Uuid
  productVariantId  String         @db.Uuid
  quantity          Int
  unitPriceSnapshot Decimal        @db.Decimal(18, 3)
  createdAt         DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime       @updatedAt @db.Timestamptz(6)
  cart              Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productVariant    ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Restrict)

  @@unique([cartId, productVariantId])
  @@index([productVariantId])
}

model CheckoutIdempotency {
  id           String                    @id @default(uuid()) @db.Uuid
  customerId   String                    @db.Uuid
  key          String                    @db.Uuid
  requestHash  String
  status       CheckoutIdempotencyStatus @default(PROCESSING)
  orderId      String?                   @unique @db.Uuid
  responseData Json?
  expiresAt    DateTime                  @db.Timestamptz(6)
  createdAt    DateTime                  @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime                  @updatedAt @db.Timestamptz(6)
  customer     Person                    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  order        Order?                    @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@unique([customerId, key])
  @@index([status, createdAt])
  @@index([expiresAt])
}

model Order {
  id                         String                 @id @default(uuid()) @db.Uuid
  orderNumber                String                 @unique
  customerId                 String                 @db.Uuid
  storeId                    String                 @db.Uuid
  status                     CommerceOrderStatus    @default(PENDING)
  fulfillmentStatus          FulfillmentStatus      @default(UNFULFILLED)
  paymentStatus              PaymentStatus          @default(UNPAID)
  paymentMethod              PaymentMethod
  fulfillmentMethod          FulfillmentMethod
  currency                   String                 @default("IQD") @db.VarChar(3)
  subtotal                   Decimal                @db.Decimal(18, 3)
  discountTotal              Decimal                @default(0) @db.Decimal(18, 3)
  deliveryFee                Decimal                @default(0) @db.Decimal(18, 3)
  taxTotal                   Decimal                @default(0) @db.Decimal(18, 3)
  grandTotal                 Decimal                @db.Decimal(18, 3)
  storeNameSnapshot          String
  storeSlugSnapshot          String
  storeLogoUrlSnapshot       String?
  storePhoneSnapshot         String?
  customerNameSnapshot       String
  customerPhoneSnapshot      String
  pickupAddressSnapshot      String?
  pickupInstructionsSnapshot String?
  preparationEstimateMinutes Int?
  deliveryEstimateMinutes    Int?
  customerInstructions       String?
  reservationExpiresAt       DateTime               @db.Timestamptz(6)
  confirmedAt                DateTime?              @db.Timestamptz(6)
  completedAt                DateTime?              @db.Timestamptz(6)
  cancelledAt                DateTime?              @db.Timestamptz(6)
  cancellationReason         String?
  rejectionReason            String?
  createdAt                  DateTime               @default(now()) @db.Timestamptz(6)
  updatedAt                  DateTime               @updatedAt @db.Timestamptz(6)
  customer                   Person                 @relation(fields: [customerId], references: [id], onDelete: Restrict)
  store                      Store                  @relation(fields: [storeId], references: [id], onDelete: Restrict)
  items                      OrderItem[]
  address                    OrderAddress?
  history                    OrderStatusHistory[]
  payment                    Payment?
  reservations               InventoryReservation[]
  stockMovements             StockMovement[]
  checkoutIdempotency        CheckoutIdempotency?

  @@index([customerId, createdAt, id])
  @@index([storeId, status, createdAt])
  @@index([status, reservationExpiresAt])
}

model OrderItem {
  id                   String                @id @default(uuid()) @db.Uuid
  orderId              String                @db.Uuid
  productId            String?               @db.Uuid
  productVariantId     String?               @db.Uuid
  productNameSnapshot  String
  variantTitleSnapshot String
  optionValuesSnapshot Json
  skuSnapshot          String
  imageUrlSnapshot     String?
  unitPrice            Decimal               @db.Decimal(18, 3)
  compareAtPrice       Decimal?              @db.Decimal(18, 3)
  quantity             Int
  lineSubtotal         Decimal               @db.Decimal(18, 3)
  lineDiscount         Decimal               @default(0) @db.Decimal(18, 3)
  lineTotal            Decimal               @db.Decimal(18, 3)
  currency             String                @default("IQD") @db.VarChar(3)
  createdAt            DateTime              @default(now()) @db.Timestamptz(6)
  order                Order                 @relation(fields: [orderId], references: [id], onDelete: Restrict)
  product              Product?              @relation(fields: [productId], references: [id], onDelete: SetNull)
  productVariant       ProductVariant?       @relation(fields: [productVariantId], references: [id], onDelete: SetNull)
  inventoryReservation InventoryReservation?

  @@index([orderId])
  @@index([productId])
  @@index([productVariantId])
}

model OrderAddress {
  id                String   @id @default(uuid()) @db.Uuid
  orderId           String   @unique @db.Uuid
  recipientName     String
  phone             String
  city              String
  area              String
  street            String
  additionalDetails String
  landmark          String?
  latitude          Decimal? @db.Decimal(9, 6)
  longitude         Decimal? @db.Decimal(9, 6)
  createdAt         DateTime @default(now()) @db.Timestamptz(6)
  order             Order    @relation(fields: [orderId], references: [id], onDelete: Restrict)
}

model OrderStatusHistory {
  id                        String               @id @default(uuid()) @db.Uuid
  orderId                   String               @db.Uuid
  previousOrderStatus       CommerceOrderStatus?
  newOrderStatus            CommerceOrderStatus?
  previousFulfillmentStatus FulfillmentStatus?
  newFulfillmentStatus      FulfillmentStatus?
  previousPaymentStatus     PaymentStatus?
  newPaymentStatus          PaymentStatus?
  actorType                 OrderActorType
  actorId                   String?
  reason                    String?
  idempotencyKey            String               @unique
  metadata                  Json?
  createdAt                 DateTime             @default(now()) @db.Timestamptz(6)
  order                     Order                @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([orderId, createdAt])
}

model Payment {
  id             String          @id @default(uuid()) @db.Uuid
  orderId        String          @unique @db.Uuid
  method         PaymentMethod
  status         PaymentStatus   @default(UNPAID)
  amount         Decimal         @db.Decimal(18, 3)
  currency       String          @default("IQD") @db.VarChar(3)
  paidAt         DateTime?       @db.Timestamptz(6)
  voidedAt       DateTime?       @db.Timestamptz(6)
  recordedByType OrderActorType?
  recordedById   String?
  createdAt      DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime        @updatedAt @db.Timestamptz(6)
  order          Order           @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([status, createdAt])
}

model CustomerFavoriteStore {
  id         String   @id @default(uuid()) @db.Uuid
  customerId String   @db.Uuid
  storeId    String   @db.Uuid
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  customer   Person   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([customerId, storeId])
  @@index([customerId, createdAt])
  @@index([storeId])
}

model CustomerFavoriteProduct {
  id         String   @id @default(uuid()) @db.Uuid
  customerId String   @db.Uuid
  productId  String   @db.Uuid
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  customer   Person   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
  @@index([customerId, createdAt])
  @@index([productId])
}

